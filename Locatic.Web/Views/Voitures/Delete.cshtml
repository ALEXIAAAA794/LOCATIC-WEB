@model Locatic.Web.Models.Voiture

@{
    ViewData["Title"] = "Supprimer une voiture";
}

<h1>Supprimer la voiture</h1>

<div class="alert alert-danger">
    Voulez-vous vraiment supprimer la voiture <strong>@Model.Immatriculation</strong> ?
</div>

<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a class="btn btn-secondary" asp-action="Index">Annuler</a>
</form>
