@model Locatic.Web.ViewModels.VoitureFormViewModel

@{
    ViewData["Title"] = "Créer une voiture";
}

<h1>Créer une voiture</h1>

<form asp-action="Create" method="post" class="row g-3">
    <div class="col-md-6">
        <label asp-for="Immatriculation" class="form-label"></label>
        <input asp-for="Immatriculation" class="form-control" />
        <span asp-validation-for="Immatriculation" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Annee" class="form-label"></label>
        <input asp-for="Annee" class="form-control" />
        <span asp-validation-for="Annee" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="TarifJournalier" class="form-label"></label>
        <input asp-for="TarifJournalier" class="form-control" />
        <span asp-validation-for="TarifJournalier" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="NombrePlaces" class="form-label"></label>
        <input asp-for="NombrePlaces" class="form-control" />
        <span asp-validation-for="NombrePlaces" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Carburant" class="form-label"></label>
        <input asp-for="Carburant" class="form-control" />
        <span asp-validation-for="Carburant" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="ModeleId" class="form-label">Modèle</label>
        <select asp-for="ModeleId" asp-items="Model.Modeles" class="form-select"></select>
        <span asp-validation-for="ModeleId" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Créer</button>
        <a class="btn btn-secondary" asp-action="Index">Retour</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
