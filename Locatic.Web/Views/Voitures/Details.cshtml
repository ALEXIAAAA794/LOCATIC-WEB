@model Locatic.Web.Models.Voiture

@{
    ViewData["Title"] = "Détails voiture";
}

<h1>Détails de la voiture</h1>

<div class="mb-3">
    <dl class="row">
        <dt class="col-sm-3">Immatriculation</dt>
        <dd class="col-sm-9">@Model.Immatriculation</dd>

        <dt class="col-sm-3">Marque</dt>
        <dd class="col-sm-9">@Model.Modele.Marque.Nom</dd>

        <dt class="col-sm-3">Modèle</dt>
        <dd class="col-sm-9">@Model.Modele.Nom</dd>

        <dt class="col-sm-3">Année</dt>
        <dd class="col-sm-9">@Model.Annee</dd>

        <dt class="col-sm-3">Carburant</dt>
        <dd class="col-sm-9">@Model.Carburant</dd>

        <dt class="col-sm-3">Tarif journalier</dt>
        <dd class="col-sm-9">@Model.TarifJournalier.ToString("C")</dd>

        <dt class="col-sm-3">Places</dt>
        <dd class="col-sm-9">@Model.NombrePlaces</dd>

        <dt class="col-sm-3">Disponible</dt>
        <dd class="col-sm-9">@(ViewData["Disponible"] as bool? == true ? "Oui" : "Non")</dd>
    </dl>
</div>

<div>
    <a class="btn btn-secondary" asp-action="Index">Retour</a>
    <a class="btn btn-warning" asp-action="Edit" asp-route-id="Model.Id">Modifier</a>
</div>
