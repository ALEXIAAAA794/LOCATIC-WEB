@model IEnumerable<Locatic.Web.Models.Client>
@{
    ViewData["Title"] = "Clients";
}
<h1 style="color: white">Liste des clients</h1>
<p>
    <a asp-action="Create" class="btn" style="background-color: green; color: white;">
        Ajouter un client
    </a>
</p>
<table class="table" style="color: white">
    <thead>
        <tr>
            <th style="color: white">Nom</th>
            <th style="color: white">Prénom</th>
            <th style="color: white">Email</th>
            <th style="color: white">Téléphone</th>
            <th style="color: white">Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var client in Model)
    {
        <tr style="color: white">
            <td>@client.Nom</td>
            <td>@client.Prenom</td>
            <td>@client.Email</td>
            <td>@client.Telephone</td>
            <td>
                <a asp-action="Details" asp-route-id="@client.Id" style="color: white">Détails</a> |
                <a asp-action="Edit" asp-route-id="@client.Id" style="color: white">Modifier</a> |
                <a asp-action="Delete" asp-route-id="@client.Id" style="color: white">Supprimer</a>
            </td>
        </tr>
    }
    </tbody>
</table>