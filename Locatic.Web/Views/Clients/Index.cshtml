@model IEnumerable<Locatic.Web.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<h1>Liste des clients</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        Ajouter un client
    </a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nom</th>
            <th>Prénom</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var client in Model)
    {
        <tr>
            <td>@client.Nom</td>
            <td>@client.Prenom</td>
            <td>@client.Email</td>
            <td>@client.Telephone</td>
            <td>
                <a asp-action="Details" asp-route-id="@client.Id">Détails</a> |
                <a asp-action="Edit" asp-route-id="@client.Id">Modifier</a> |
                <a asp-action="Delete" asp-route-id="@client.Id">Supprimer</a>
            </td>
        </tr>
    }
    </tbody>
</table>