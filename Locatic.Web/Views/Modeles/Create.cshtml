@model Locatic.Web.Models.Modele

@{
    ViewData["Title"] = "Créer un modèle";
}

<h1>Créer un modèle</h1>

<form asp-action="Create" method="post" class="row g-3">
    <div class="col-md-6">
        <label asp-for="Nom" class="form-label"></label>
        <input asp-for="Nom" class="form-control" />
        <span asp-validation-for="Nom" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="MarqueId" class="form-label">Marque</label>
        <select asp-for="MarqueId" class="form-select" asp-items="@(ViewData["Marques"] as SelectList)"></select>
        <span asp-validation-for="MarqueId" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Ajouter</button>
        <a class="btn btn-secondary" asp-action="Index">Retour</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
